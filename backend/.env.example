# ── LLM Providers ──────────────────────────────────────────
# Choose one: "claude" | "openai" | "ollama"
LLM_PROVIDER=claude

ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Ollama runs locally — no key needed, just set the base URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── News ────────────────────────────────────────────────────
# Optional: NewsAPI key from newsapi.org (free tier = 100 req/day)
# If left empty, falls back to Google News RSS (no key needed)
NEWS_API_KEY=your_newsapi_key_here
DATABASE_URL=postgresql://postgres:password@localhost:5432/supply_chain_risk
